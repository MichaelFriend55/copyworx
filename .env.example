# Copy this file to .env.local and fill in the real values.
# Never commit .env.local — it contains secrets.
# .env.example is safe to commit: it holds only placeholder values.

# ─── Authentication (Clerk) ──────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# ─── AI Provider (Anthropic) ─────────────────────────────────────────────────
# Get this from https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-your_anthropic_api_key_here

# ─── Database (Supabase) ─────────────────────────────────────────────────────
# Get these from https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─── Payments (Stripe) ───────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key_here
# Find price IDs in https://dashboard.stripe.com → Products
STRIPE_PRICE_ID=price_your_stripe_price_id_here
# Find webhook secrets in https://dashboard.stripe.com → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# ─── Analytics (Google Analytics) ────────────────────────────────────────────
# Get this from https://analytics.google.com → Admin → Data Streams
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Feature Flags ───────────────────────────────────────────────────────────
# Set to 'true' to enable the WORX DESK brief-to-copy on-ramp. Defaults to false.
NEXT_PUBLIC_WORXDESK_ENABLED=false
